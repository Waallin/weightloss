{
  "expo": {
    "name": "Kudoo",
    "slug": "kudoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devember.kudoo",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select a profile picture.",
        "NSCameraUsageDescription": "This app needs access to your camera to take a new profile picture.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to capture photos with sound."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.devember.kudoo",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2aa66fc6-704b-4789-996e-0c826ed90bd9"
      }
    },
    "owner": "waallin"
  }
}
